{
  "schema_version": "1.0",
  "service_name": "bin-transcribe-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/transcribes$"
    },
    {
      "pattern": "/v1/transcribes\\?"
    },
    {
      "pattern": "/v1/transcribes/{{UUID}}$"
    },
    {
      "pattern": "/v1/transcribes/{{UUID}}/health-check$"
    },
    {
      "pattern": "/v1/transcribes/{{UUID}}/stop$"
    },
    {
      "pattern": "/v1/transcripts\\?"
    }
  ],
  "events_subscribed": [
    {
      "queue_symbol": "bin-manager.call-manager.event"
    },
    {
      "queue_symbol": "bin-manager.customer-manager.event"
    }
  ],
  "events_published": [
    {
      "event_type_symbol": "transcribe.EventTypeTranscribeCreated"
    },
    {
      "event_type_symbol": "transcribe.EventTypeTranscribeDone"
    },
    {
      "event_type_symbol": "transcribe.EventTypeTranscribeProgressing"
    }
  ],
  "dependencies": [
