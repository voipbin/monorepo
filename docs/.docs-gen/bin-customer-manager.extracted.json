{
  "schema_version": "1.0",
  "service_name": "bin-customer-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/accesskeys$"
    },
    {
      "pattern": "/v1/accesskeys\\?(.*)$"
    },
    {
      "pattern": "/v1/accesskeys/{{UUID}}$"
    },
    {
      "pattern": "/v1/customers$"
    },
    {
      "pattern": "/v1/customers\\?(.*)$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}/billing_account_id$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}/metadata$"
    },
    {
      "pattern": "/v1/customers/signup$"
    },
    {
      "pattern": "/v1/customers/email_verify$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}/freeze$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}/recover$"
    },
    {
      "pattern": "/v1/customers/{{UUID}}/freeze_and_delete$"
    }
  ],
