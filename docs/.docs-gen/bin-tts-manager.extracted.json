{
  "schema_version": "1.0",
  "service_name": "bin-tts-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/speeches"
    },
    {
      "pattern": "/v1/speakings(\\?|$)"
    },
    {
      "pattern": "/v1/speakings/{{UUID}}$"
    },
    {
      "pattern": "/v1/speakings/{{UUID}}/say$"
    },
    {
      "pattern": "/v1/speakings/{{UUID}}/flush$"
    },
    {
      "pattern": "/v1/speakings/{{UUID}}/stop$"
    },
    {
      "pattern": "/v1/streamings$"
    },
    {
      "pattern": "/v1/streamings/{{UUID}}$"
    },
    {
      "pattern": "/v1/streamings/{{UUID}}/say_add$"
    },
    {
      "pattern": "/v1/streamings/{{UUID}}/say_init$"
    },
    {
      "pattern": "/v1/streamings/{{UUID}}/say_stop$"
    },
    {
      "pattern": "/v1/streamings/{{UUID}}/say_finish$"
    }
  ],
  "events_subscribed": [],
  "events_published": [],
