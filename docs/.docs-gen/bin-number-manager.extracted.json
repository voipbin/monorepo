{
  "schema_version": "1.0",
  "service_name": "bin-number-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/available_numbers"
    },
    {
      "pattern": "/v1/numbers\\?"
    },
    {
      "pattern": "/v1/numbers$"
    },
    {
      "pattern": "/v1/numbers/{{UUID}}$"
    },
    {
      "pattern": "/v1/numbers/{{UUID}}/flow_ids$"
    },
    {
      "pattern": "/v1/numbers/{{UUID}}/metadata$"
    },
    {
      "pattern": "/v1/numbers/renew$"
    },
    {
      "pattern": "/v1/numbers/count_virtual_by_customer$"
    }
  ],
  "events_subscribed": [
    {
      "queue_symbol": "bin-manager.flow-manager.event"
    },
    {
      "queue_symbol": "bin-manager.customer-manager.event"
    }
  ],
  "events_published": [
    {
      "event_type_symbol": "number.EventTypeNumberCreated"
    },
    {
      "event_type_symbol": "number.EventTypeNumberDeleted"
    }
  ],
