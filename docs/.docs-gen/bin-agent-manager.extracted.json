{
  "schema_version": "1.0",
  "service_name": "bin-agent-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/agents/count_by_customer$"
    },
    {
      "pattern": "/v1/agents$"
    },
    {
      "pattern": "/v1/agents\\?(.*)$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/login$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/addresses$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/tag_ids$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/status$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/password$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/permission$"
    },
    {
      "pattern": "/v1/agents/{{UUID}}/direct-hash-regenerate$"
    },
    {
      "pattern": "/v1/agents/get_by_customer_id_address$"
    },
    {
      "pattern": "/v1/login$"
    },
    {
      "pattern": "/v1/password-forgot$"
    },
    {
      "pattern": "/v1/password-reset$"
    }
  ],
  "events_subscribed": [
    {
      "queue_symbol": "bin-manager.call-manager.event"
    },
    {
      "queue_symbol": "bin-manager.customer-manager.event"
    },
    {
      "queue_symbol": "bin-manager.webhook-manager.event"
    }
  ],
  "events_published": [
