    },
    {
      "event_type_symbol": "agent.EventTypeAgentDeleted"
    },
    {
      "event_type_symbol": "agent.EventTypeAgentStatusUpdated"
    },
    {
      "event_type_symbol": "agent.EventTypeAgentUpdated"
    }
  ],
