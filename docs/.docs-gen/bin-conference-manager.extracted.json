{
  "schema_version": "1.0",
  "service_name": "bin-conference-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/conferences/count_by_customer$"
    },
    {
      "pattern": "/v1/conferences$"
    },
    {
      "pattern": "/v1/conferences\\?"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/direct-hash-regenerate$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/recording_id$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/recording_start$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/recording_stop$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/stop$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/transcribe_start$"
    },
    {
      "pattern": "/v1/conferences/{{UUID}}/transcribe_stop$"
    },
    {
      "pattern": "/v1/conferencecalls\\?"
    },
    {
      "pattern": "/v1/conferencecalls/{{UUID}}$"
    },
    {
      "pattern": "/v1/conferencecalls/{{UUID}}/health-check$"
    },
    {
      "pattern": "/v1/services/type/conferencecall$"
    }
  ],
  "events_subscribed": [
    {
      "queue_symbol": "bin-manager.call-manager.event"
    }
  ],
  "events_published": [
    {
      "event_type_symbol": "conference.EventTypeConferenceCreated"
    },
    {
      "event_type_symbol": "conference.EventTypeConferenceDeleted"
    },
    {
      "event_type_symbol": "conference.EventTypeConferenceUpdated"
    }
  ],
