{
  "schema_version": "1.0",
  "service_name": "bin-conversation-manager",
  "service_class": "A",
  "routing_table": [
    {
      "pattern": "/v1/accounts\\?"
    },
    {
      "pattern": "/v1/accounts$"
    },
    {
      "pattern": "/v1/accounts/{{UUID}}$"
    },
    {
      "pattern": "/v1/conversations\\?"
    },
    {
      "pattern": "/v1/conversations$"
    },
    {
      "pattern": "/v1/conversations/self_and_peer$"
    },
    {
      "pattern": "/v1/conversations/get_or_create_by_self_and_peer$"
    },
    {
      "pattern": "/v1/conversations/create_and_execute_flow$"
    },
    {
      "pattern": "/v1/conversations/{{UUID}}$"
    },
    {
      "pattern": "/v1/conversations/{{UUID}}/metadata$"
    },
    {
      "pattern": "/v1/hooks$"
    },
    {
      "pattern": "/v1/messages\\?"
    },
    {
      "pattern": "/v1/messages$"
    },
    {
      "pattern": "/v1/messages/create$"
    }
  ],
  "events_subscribed": [
    {
      "queue_symbol": "bin-manager.message-manager.event"
    },
    {
      "queue_symbol": "bin-manager.email-manager.event"
    },
    {
      "queue_symbol": "bin-manager.webchat-manager.event"
    }
  ],
  "events_published": [
    {
      "event_type_symbol": "conversation.EventTypeConversationCreated"
    },
    {
      "event_type_symbol": "conversation.EventTypeConversationUpdated"
    },
    {
      "event_type_symbol": "message.EventTypeMessageCreated"
    },
    {
      "event_type_symbol": "message.EventTypeMessageDeleted"
    },
    {
      "event_type_symbol": "message.EventTypeMessageUpdated"
    }
  ],
  "dependencies": [
