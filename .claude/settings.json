{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-magic-strings.sh",
            "description": "Check for hardcoded direct resource type magic strings in .go files"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/check-rst-build.sh",
            "description": "Remind to rebuild RST HTML docs when source .rst files are edited"
          }
        ]
      }
    ]
  }
}
