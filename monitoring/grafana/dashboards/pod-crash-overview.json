        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "title": "Pods Currently Crash Looping",
      "type": "stat",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "count(increase(kube_pod_container_status_restarts_total{namespace=~\"bin-manager|voip\"}[15m]) > 3) OR vector(0)",
